---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site.config';

const formUrl = site.registrationFormUrl;
const emailSubject = 'Inscription KMIS - Krav Maga Limeil-Brévannes';
const emailBody = [
  'Bonjour,',
  '',
  'Je souhaite recevoir les informations pour finaliser une inscription KMIS.',
  '',
  'Nom :',
  'Prénom :',
  'Téléphone :',
  'Email :',
  'Adulte ou mineur :',
  'Créneau souhaité :',
  '',
  'Cordialement'
].join('\r\n');
---
<BaseLayout
  title="Inscription Krav Maga à Limeil-Brévannes"
  description="Préparez votre inscription à Krav Maga Instinctive System à Limeil-Brévannes avec un formulaire en ligne, sans impression papier."
>
  <section class="hero">
    <div class="container">
        <p class="eyebrow">Adhésion KMIS</p>
        <h1>Préparer son inscription en ligne.</h1>
        <p class="lead">Ce formulaire constitue votre demande d’adhésion au club KMIS. Il confirme votre engagement à pratiquer dans le respect du règlement intérieur, des consignes de sécurité et des valeurs de l’association. L’inscription sera définitive après validation du dossier et règlement de la cotisation.</p>
        <div class="actions">
          {formUrl ? (
            <a class="btn btn-primary" href="#formulaire">Remplir le formulaire</a>
          ) : (
            <a class="btn btn-primary" href={`mailto:${site.email}?subject=${encodeURIComponent(emailSubject)}&body=${encodeURIComponent(emailBody)}`}>Contacter l’association</a>
          )}
          <a class="btn btn-secondary" href="/inscription-essai/">Demander un cours d’essai</a>
        </div>
    </div>
  </section>

  <section class="section" id="formulaire">
    <div class="container">
      <div class="section-header">
        <p class="eyebrow">Formulaire</p>
        <h2>Inscription KMIS</h2>
      </div>

      {formUrl ? (
        <div class="form-frame">
          <iframe
            src={formUrl}
            title="Formulaire d’inscription KMIS"
            width="100%"
            height="900"
            loading="lazy"
          ></iframe>
        </div>
      ) : (
        <div class="notice registration-notice">
          <strong>Formulaire en préparation.</strong>
          <p>En attendant l’activation du formulaire en ligne, contactez l’association pour recevoir les consignes d’inscription et les documents à fournir.</p>
          <div class="actions">
            <a class="btn btn-primary" href={`mailto:${site.email}?subject=${encodeURIComponent(emailSubject)}&body=${encodeURIComponent(emailBody)}`}>Écrire à {site.email}</a>
            {site.whatsapp && (
              <a class="btn btn-secondary" href={`https://wa.me/${site.whatsapp}?text=${encodeURIComponent('Bonjour, je souhaite préparer une inscription KMIS à ' + site.city + '.')}`} target="_blank" rel="noopener">WhatsApp</a>
            )}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .form-frame {
    border: 1px solid var(--line); border-radius: var(--radius);
    overflow: hidden; background: #fff;
    min-height: 900px;
  }
  .form-frame iframe {
    display: block; border: 0; background: #fff;
  }
  .registration-notice p {
    margin-top: 10px;
  }
</style>
