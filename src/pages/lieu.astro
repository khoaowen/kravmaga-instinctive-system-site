---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site.config';
---
<BaseLayout
  title="Lieu des cours de Krav Maga à Limeil-Brévannes"
  description="Lieu d’entraînement de Krav Maga Instinctive System à Limeil-Brévannes, accès, adresse et informations pratiques."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Accès</p>
      <h1>Lieu d’entraînement à {site.city}</h1>
      <p class="lead">Les cours ont lieu à Limeil-Brévannes, à l’adresse indiquée sur la fiche Google Maps de l’association.</p>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="card">
        <h2>Adresse</h2>
        <p><strong>{site.address}</strong></p>
        <p>Contactez l’association pour les informations d’inscription, les horaires confirmés et les consignes d’accueil.</p>
      </div>
    </div>
  </section>
  {site.googleMapsEmbedUrl && (
    <section class="section">
      <div class="container">
        <div class="map-embed">
          <iframe
            title={`Carte Google Maps - ${site.address}`}
            src={site.googleMapsEmbedUrl}
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            allowfullscreen
          />
        </div>
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .map-embed {
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: var(--panel);
    min-height: 360px;
  }

  .map-embed iframe {
    display: block;
    width: 100%;
    height: min(62vh, 520px);
    min-height: 360px;
    border: 0;
  }
</style>
