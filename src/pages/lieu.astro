---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../site.config';
---
<BaseLayout
  title="Lieu des cours de Krav Maga à Limeil-Brévannes"
  description="Lieu d’entraînement de Krav Maga Instinctive System à Limeil-Brévannes, accès, adresse et informations pratiques."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Accès</p>
      <h1>Lieu d’entraînement à {site.city}</h1>
      <p class="lead">Les cours ont lieu à Limeil-Brévannes, à l’adresse indiquée sur la fiche Google Maps de l’association.</p>
    </div>
  </section>
  <section class="section">
    <div class="container grid-2">
      <div class="card">
        <h2>Adresse</h2>
        <p><strong>{site.address}</strong></p>
        <p>Contactez l’association pour les informations d’inscription, les horaires confirmés et les consignes d’accueil.</p>
        {site.googleMapsUrl ? <a class="btn btn-primary" href={site.googleMapsUrl}>Ouvrir dans Google Maps</a> : <p class="notice">Lieu d’entraînement communiqué prochainement</p>}
      </div>
      <div class="card">
        <h2>Communes proches</h2>
        <p>Le club peut intéresser les personnes qui cherchent du Krav Maga près de :</p>
        <div class="pill-list">
          {[site.city, ...site.nearbyCities].map((city) => <span class="pill">{city}</span>)}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
