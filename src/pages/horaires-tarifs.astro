---
import BaseLayout from '../layouts/BaseLayout.astro';
import { schedule, prices } from '../site.config';
---
<BaseLayout
  title="Horaires et tarifs Krav Maga"
  description="Horaires, tarifs et informations pratiques pour les cours de Krav Maga Instinctive System à Limeil-Brévannes."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Informations pratiques</p>
      <h1>Horaires et tarifs</h1>
      <p class="lead">Retrouvez les créneaux d’entraînement, les tarifs de cotisation et les informations à prévoir pour l’inscription.</p>
    </div>
  </section>
  <section class="section">
    <div class="container practical-grid">
      <div class="card">
        <h2>Horaires des cours</h2>
        <table class="table">
          <thead><tr><th>Jour</th><th>Horaire</th><th>Public</th></tr></thead>
          <tbody>
            {schedule.map((item) => <tr><td>{item.day}</td><td>{item.time}</td><td>{item.audience}</td></tr>)}
          </tbody>
        </table>
      </div>
      <div class="card pricing-card">
        <h2>Tarifs saison 2025/2026</h2>
        <table class="table pricing-table">
          <thead>
            <tr>
              <th>Catégorie</th>
              <th>Cotisation</th>
              <th>Licence</th>
              <th>Réduction</th>
              <th>Total</th>
              <th>Commentaire</th>
            </tr>
          </thead>
          <tbody>
            {prices.map((item) => (
              <tr>
                <td>{item.category}</td>
                <td>{item.membership}</td>
                <td>{item.license}</td>
                <td>{item.discount}</td>
                <td><strong>{item.total}</strong></td>
                <td>{item.comment ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container">
      <div class="notice">
        <strong>Inscription :</strong> les réductions s’appliquent sur la cotisation. La licence reste à 24 €. Le formulaire en ligne permet de transmettre les informations d’adhésion sans impression papier. <a href="/inscription/">Préparer l’inscription</a>.
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .practical-grid {
    display: grid;
    gap: 18px;
  }

  .pricing-card { overflow-x: auto; }
  .pricing-table {
    table-layout: auto;
  }
  .pricing-table td:first-child { color: var(--text); font-weight: 800; }
  .pricing-table strong { color: var(--text); font-size: 1.08rem; }
  @media (max-width: 720px) {
    .pricing-table { min-width: 700px; }
  }
</style>
