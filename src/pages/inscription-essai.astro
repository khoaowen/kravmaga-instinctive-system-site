---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, trialLesson } from '../site.config';

const trialEmailBody = [
  'Bonjour,',
  '',
  trialLesson.whatsappText,
  '',
  ...trialLesson.messageChecklist.map((item) => item + ' :'),
  '',
  'Cordialement'
].join('\r\n');
---
<BaseLayout
  title="Cours d’essai Krav Maga à Limeil-Brévannes"
  description="Demandez un cours d’essai de Krav Maga à Limeil-Brévannes. Informations à envoyer, tenue conseillée et préparation du premier cours."
>
  <section class="hero">
    <div class="container">
      <p class="eyebrow">Commencer</p>
      <h1>Demander un cours d’essai</h1>
      <p class="lead">{trialLesson.beginnerReassurance}</p>
      <div class="actions">
        {site.whatsapp && (
          <a class="btn btn-primary" href={`https://wa.me/${site.whatsapp}?text=${encodeURIComponent(trialLesson.whatsappText)}`} target="_blank" rel="noopener">Écrire sur WhatsApp</a>
        )}
        {site.phone && <a class="btn btn-secondary" href={`tel:${site.phoneHref}`}>Appeler le {site.phone}</a>}
        <a class="btn btn-secondary" href={`mailto:${site.email}?subject=${encodeURIComponent(trialLesson.emailSubject)}&body=${encodeURIComponent(trialEmailBody)}`}>Envoyer un e-mail</a>
      </div>
    </div>
  </section>
  <section class="section">
    <div class="container grid-3">
      <article class="card">
        <h2>À envoyer</h2>
        <ul class="list">
          {trialLesson.messageChecklist.map((item) => <li>{item}.</li>)}
        </ul>
      </article>
      <article class="card">
        <h2>À prévoir</h2>
        <ul class="list">
          {trialLesson.bringChecklist.map((item) => <li>{item}.</li>)}
        </ul>
      </article>
      <article class="card">
        <h2>Premier cours</h2>
        <ul class="list">
          {trialLesson.firstClassNotes.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </section>
</BaseLayout>
