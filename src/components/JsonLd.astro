---
import { site, schedule, instructor } from '../site.config';

const openingHours = schedule
  .filter((item) => !item.time.includes('communiqués prochainement'))
  .map((item) => `${item.day} ${item.time}`);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': ['SportsActivityLocation', 'SportsOrganization'],
  name: site.name,
  alternateName: site.shortName,
  sport: 'Krav Maga',
  description: `Association de Krav Maga et self-défense à ${site.city}. Cours pour adultes, débutants et pratiquants souhaitant apprendre à se protéger.` ,
  url: site.domain,
  email: site.email,
  telephone: site.phoneHref || site.phone || undefined,
  founder: {
    '@type': 'Person',
    name: instructor.name,
    jobTitle: 'Instructeur de Krav Maga, éducateur sportif diplômé d’État',
    image: new URL(instructor.photo, site.domain).href
  },
  hasMap: site.googleMapsUrl || undefined,
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.latitude,
    longitude: site.longitude
  },
  address: {
    '@type': 'PostalAddress',
    streetAddress: site.streetAddress,
    addressLocality: site.city,
    postalCode: site.postalCode,
    addressRegion: site.region,
    addressCountry: site.country
  },
  areaServed: [site.city, ...site.nearbyCities],
  openingHours: openingHours.length ? openingHours : undefined,
  sameAs: [site.facebook, site.instagram].filter(Boolean)
};
---
<script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
